# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=llm_observability
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=llm_password

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Producer ───────────────────────────────────────────────────────────────
# Events per second the simulator will produce
EVENTS_PER_SECOND=2

# ── Flink Jobs ─────────────────────────────────────────────────────────────
# Cost rollup window size in minutes (use 5 for demos, 60 for production)
ROLLUP_WINDOW_MINUTES=5
# Anomaly detection window size in minutes
ANOMALY_WINDOW_MINUTES=5

# ── LiteLLM (only needed for --profile live) ───────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
